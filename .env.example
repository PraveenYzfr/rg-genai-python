# =============================================================================
# Provider Selection — switch based on your need
# =============================================================================
# Options: openai | groq | gemini | ollama
DEFAULT_LLM_PROVIDER=openai
DEFAULT_EMBEDDING_PROVIDER=openai

# =============================================================================
# OpenAI (paid, best quality)
# Get key: https://platform.openai.com/api-keys
# =============================================================================
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# =============================================================================
# Groq (FREE tier, very fast)
# Get key: https://console.groq.com/keys
# =============================================================================
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile

# =============================================================================
# Google Gemini (FREE tier)
# Get key: https://aistudio.google.com/apikey
# =============================================================================
GOOGLE_API_KEY=
GEMINI_MODEL=gemini-2.0-flash
GEMINI_EMBEDDING_MODEL=models/text-embedding-004

# =============================================================================
# Ollama (100% FREE, runs locally — no API key needed)
# Install: https://ollama.com  then run: ollama pull llama3.2
#          ollama pull nomic-embed-text
# =============================================================================
OLLAMA_ENABLED=false
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2
OLLAMA_EMBEDDING_MODEL=nomic-embed-text

# =============================================================================
# RAG / Vector Store
# =============================================================================
CHROMA_PERSIST_DIR=./data/chroma
CHROMA_COLLECTION_NAME=rggenai_docs
RAG_CHUNK_SIZE=1000
RAG_CHUNK_OVERLAP=200
RAG_TOP_K=5

# =============================================================================
# API Server
# =============================================================================
API_HOST=0.0.0.0
API_PORT=8000
API_RELOAD=true
LOG_LEVEL=INFO

# LangGraph checkpoint persistence
CHECKPOINT_DB_PATH=./data/checkpoints.db

# MCP Server
MCP_SERVER_NAME=rggenai-mcp
MCP_TRANSPORT=stdio
