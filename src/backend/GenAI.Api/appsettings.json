{
  "ConnectionStrings": {
    "DefaultConnection": "Host=localhost;Port=5432;Database=genai;Username=postgres;Password=postgres"
  },
  "LLM": {
    "DefaultProvider": "OpenAI",
    "DefaultModel": "gpt-4o-mini",
    "OpenAI": {
      "Enabled": true,
      "ApiKey": "",
      "DefaultModel": "gpt-4o-mini",
      "EmbeddingModel": "text-embedding-3-small"
    },
    "Claude": {
      "Enabled": true,
      "ApiKey": "",
      "DefaultModel": "claude-3-5-sonnet-20241022",
      "ApiUrl": "https://api.anthropic.com/v1/messages"
    },
    "Gemini": {
      "Enabled": true,
      "ApiKey": "",
      "DefaultModel": "gemini-1.5-pro"
    },
    "ModelMappings": [
      { "Key": "gpt-4o-mini", "Provider": "OpenAI", "Model": "gpt-4o-mini" },
      { "Key": "gpt-4o", "Provider": "OpenAI", "Model": "gpt-4o" },
      { "Key": "claude-3-5-sonnet", "Provider": "Claude", "Model": "claude-3-5-sonnet-20241022" },
      { "Key": "gemini-1.5-pro", "Provider": "Gemini", "Model": "gemini-1.5-pro" }
    ]
  },
  "RAG": {
    "ChunkSize": 1000,
    "ChunkOverlap": 200,
    "DefaultTopK": 5,
    "EmbeddingDimensions": 1536,
    "StoragePath": "uploads"
  },
  "Agents": {
    "DefaultMaxIterations": 10,
    "DefaultModelKey": "gpt-4o-mini"
  },
  "Jira": {
    "BaseUrl": "",
    "Email": "",
    "ApiToken": "",
    "ProjectKey": "RG",
    "UseMockData": true
  },
  "ServiceNow": {
    "InstanceUrl": "",
    "Username": "",
    "Password": "",
    "UseMockData": true
  },
  "Serilog": {
    "Using": [ "Serilog.Sinks.Console", "Serilog.Sinks.File" ],
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "Microsoft.AspNetCore": "Warning",
        "Microsoft.EntityFrameworkCore": "Warning"
      }
    },
    "WriteTo": [
      { "Name": "Console" },
      {
        "Name": "File",
        "Args": {
          "path": "logs/genai-.log",
          "rollingInterval": "Day",
          "retainedFileCountLimit": 7
        }
      }
    ],
    "Enrich": [ "FromLogContext" ]
  },
  "AllowedHosts": "*"
}
